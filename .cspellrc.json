{
  "version": "0.2",
  "language": "en",
  "ignorePaths": [
    "node_modules",
    "out",
    "dist",
    ".git",
    ".vscode-test",
    "*.ditaval"
  ],
  "overrides": [
    {
      "filename": "**/*.{dita,ditamap,bookmap,xml}",
      "ignoreRegExpList": [
        "<[^>]+>",
        "\\s[a-zA-Z-]+=(\"[^\"]*\"|'[^']*')"
      ]
    },
    {
      "filename": "src/**/*.ts",
      "words": [
        "dita",
        "dtd",
        "conref",
        "keyref",
        "topicref",
        "ditamap",
        "xml",
        "xpath",
        "oasis",
        "vscode",
        "textmate"
      ]
    }
  ]
}
