@startuml DitaCraft Architecture

!theme plain
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho

title DitaCraft VS Code Extension - Architecture (v0.6.2)

' ===== PACKAGES =====

package "Extension Core" {
    class Extension <<entry point>> {
        +activate(context: ExtensionContext): void
        +deactivate(): void
        +getOutputChannel(): OutputChannel
        +getDitaOtWrapper(): DitaOtWrapper
        -registerCommands(): void
        -registerProviders(): void
        -startLanguageClient(): void
        -registerActivityBarViews(): void
    }
}

package "Commands" {
    class ValidateCommand <<module>> {
        +initializeValidator(context: ExtensionContext): void
        +validateCommand(uri?: Uri): Promise<void>
        +getValidator(): DitaValidator | undefined
        -clearStaleDiagnosticsOnSave(): void
    }

    class PublishCommand <<module>> {
        +publishCommand(uri?: Uri): Promise<void>
        +publishHTML5Command(uri?: Uri): Promise<void>
        -selectTranstype(): Promise<string | undefined>
    }

    class PreviewCommand <<module>> {
        +previewHTML5Command(uri?: Uri): Promise<void>
        -generatePreview(inputFile: string): Promise<string>
    }

    class FileCreationCommands <<module>> {
        +newTopicCommand(): Promise<void>
        +newMapCommand(): Promise<void>
        +newBookmapCommand(): Promise<void>
    }

    class CSpellSetupCommand <<module>> {
        +setupCSpellCommand(): Promise<void>
    }
}

package "Providers" {
    class DitaValidator {
        -diagnosticCollection: DiagnosticCollection
        +validateFile(uri: Uri): Promise<ValidationResult>
        +clearDiagnostics(uri: Uri): void
        +dispose(): void
    }

    class DitaLinkProvider implements DocumentLinkProvider {
        -keySpaceResolver: KeySpaceResolver
        +provideDocumentLinks(document, token): Promise<DocumentLink[]>
    }

    class DitaExplorerProvider implements TreeDataProvider {
        +getTreeItem(element): TreeItem
        +getChildren(element?): Thenable<TreeItem[]>
        +refresh(): void
    }

    class KeySpaceViewProvider implements TreeDataProvider {
        +getTreeItem(element): TreeItem
        +getChildren(element?): Thenable<TreeItem[]>
        +refresh(): void
    }

    class DiagnosticsViewProvider implements TreeDataProvider {
        +getTreeItem(element): TreeItem
        +getChildren(element?): Thenable<TreeItem[]>
        -_collectDitaDiagnostics(): DiagnosticEntry[]
        -deduplicateByKey(): void
    }

    class DitaFileDecorationProvider implements FileDecorationProvider {
        +provideFileDecoration(uri): FileDecoration
    }

    class PreviewPanel {
        +createOrShow(htmlPath: string): void
        +dispose(): void
    }

    class MapVisualizerPanel {
        +show(mapPath: string): void
        +dispose(): void
    }
}

package "Client Utils" {
    class KeySpaceResolver implements Disposable {
        -keySpaceCache: Map<string, KeySpace>
        +resolveKey(keyName, contextFile): Promise<string | undefined>
        +invalidateCacheForFile(filePath): void
    }

    class DitaOtWrapper {
        +isAvailable(): Promise<boolean>
        +publish(options: PublishOptions): Promise<string>
    }

    class ConfigurationManager {
        +get<T>(key: string): T
        +onConfigurationChange(listener): Disposable
    }

    class RateLimiter {
        +isAllowed(key: string): boolean
        +getStats(): RateLimiterStats
    }

    class MapHierarchyParser {
        +parseMapHierarchy(mapPath): Promise<MapNode[]>
    }
}

package "LSP Server" <<Node>> {
    class Server <<entry point>> {
        -connection: Connection
        -documents: TextDocuments
        +initialize(): void
        +registerHandlers(): void
        -smartDebounce(uri, delay): void
        -TOPIC_DEBOUNCE_MS: 300
        -MAP_DEBOUNCE_MS: 1000
    }

    package "Validation Pipeline" {
        class ValidationTS <<Layer 1+4>> {
            +validateDITADocument(doc, settings): Diagnostic[]
            -validateXML(text): void
            -validateTopicStructure(text): void
            -validateMapStructure(text): void
            -validateBookmapStructure(text): void
            -checkTopicrefsWithoutHref(text): void
            -validateIDs(text): void
            -offsetToRange(text, start, end): Range
            -createRange(line, col, length?): Range
        }

        class CatalogValidationService <<Layer 2>> {
            -typesxml: TypesXMLModule
            -catalog: TypesXMLCatalog
            -parserPool: ParserPair[3]
            +initialize(extensionPath): void
            +validate(text): Diagnostic[]
            +isAvailable: boolean
        }

        class RngValidationService <<Layer 3>> {
            -grammarCache: Map (max 20)
            +initialize(schemaPath): void
            +validate(text): Diagnostic[]
            +isAvailable: boolean
        }

        class DitaRulesValidator <<Layer 5>> {
            +validateDitaRules(text, settings): Diagnostic[]
            -rules: DitaRule[35]
            -filterByVersion(version): DitaRule[]
        }

        class CrossRefValidation <<Layer 6a>> {
            +validateCrossReferences(text, uri, ...): Diagnostic[]
            -validateHref(text): void
            -validateConref(text): void
            -validateKeyref(text): void
        }

        class ProfilingValidation <<Layer 6b>> {
            +validateProfilingAttributes(text, ...): Diagnostic[]
        }
    }

    package "LSP Features" {
        class Completion {
            +handleCompletion(params): CompletionItem[]
        }
        class Hover {
            +handleHover(params): Hover | null
        }
        class CodeActions {
            +handleCodeActions(params): CodeAction[]
        }
        class Definition {
            +handleDefinition(params): Location | null
        }
        class References {
            +handleReferences(params): Location[]
        }
        class Rename {
            +handleRename(params): WorkspaceEdit
        }
        class Formatting {
            +handleFormatting(params): TextEdit[]
        }
        class Symbols {
            +handleDocumentSymbol(params): DocumentSymbol[]
            +handleWorkspaceSymbol(params): SymbolInformation[]
        }
    }

    package "Server Services" {
        class KeySpaceService {
            -keySpaceCache: Map<string, KeySpace>
            +resolveKey(keyName, contextFile): KeyDefinition | null
            +buildKeySpace(rootMap): Promise<KeySpace>
        }

        class SubjectSchemeService {
            -schemeCache: Map<string, SchemeData>
            +getValidValues(element, attribute): string[] | null
            +registerSchemes(schemePaths): void
        }
    }

    package "Server Utils" {
        class XmlTokenizer <<generator>> {
            +tokenize(input): Generator<Token>
            +findAttributeAtOffset(input, offset): AttributeInfo
            +findContextAtOffset(input, offset): ContextInfo
        }

        class ReferenceParser {
            +parseReference(ref): ParsedReference
            +findReferenceAtOffset(text, offset): RefInfo
        }

        class I18n {
            +t(key, ...args): string
            +setLocale(locale): void
        }
    }
}

' ===== RELATIONSHIPS =====

' Extension core
Extension ..> ValidateCommand : registers
Extension ..> PublishCommand : registers
Extension ..> PreviewCommand : registers
Extension ..> FileCreationCommands : registers
Extension ..> CSpellSetupCommand : registers
Extension ..> DitaValidator : creates
Extension ..> DitaLinkProvider : registers
Extension ..> DitaExplorerProvider : registers
Extension ..> KeySpaceViewProvider : registers
Extension ..> DiagnosticsViewProvider : registers
Extension ..> DitaFileDecorationProvider : registers
Extension ..> Server : starts via IPC

' Client-side
ValidateCommand ..> DitaValidator : uses
DitaValidator ..> RateLimiter : checks
DitaLinkProvider *-- KeySpaceResolver : uses
DitaExplorerProvider ..> MapHierarchyParser : uses
PublishCommand ..> DitaOtWrapper : uses
PreviewCommand ..> DitaOtWrapper : uses

' LSP Server internal
Server ..> ValidationTS : delegates
Server ..> CatalogValidationService : delegates
Server ..> RngValidationService : delegates
Server ..> DitaRulesValidator : delegates
Server ..> CrossRefValidation : delegates
Server ..> ProfilingValidation : delegates
Server ..> Completion : delegates
Server ..> Hover : delegates
Server ..> CodeActions : delegates
Server ..> Definition : delegates
Server ..> Symbols : delegates

' Feature dependencies
Completion ..> KeySpaceService : uses
Completion ..> SubjectSchemeService : uses
Hover ..> KeySpaceService : uses
Definition ..> KeySpaceService : uses
CrossRefValidation ..> KeySpaceService : uses
ProfilingValidation ..> SubjectSchemeService : uses
DitaRulesValidator ..> I18n : uses
ValidationTS ..> I18n : uses

' ===== NOTES =====

note top of Extension
    Entry point for VS Code extension.
    Manages lifecycle, registers commands,
    starts LSP server via IPC.
end note

note right of Server
    **LSP Server (v0.6.2)**
    - Pull-based diagnostics (LSP 3.17)
    - Smart debouncing (300ms/1000ms)
    - Per-document cancellation
    - 14 language features
    - 70 localized diagnostic messages
end note

note left of ValidationTS
    **6-Layer Validation Pipeline**
    L1: XML well-formedness
    L2: DTD (TypesXML + catalog)
    L3: RNG (salve-annos, optional)
    L4: DITA structure + IDs
    L5: 35 DITA rules
    L6: Cross-refs + profiling
end note

note bottom of DiagnosticsViewProvider
    **Deduplication (v0.6.2)**
    Filters identical diagnostics by
    file:line:col:severity:message key
end note

note right of DitaValidator
    **Client-side (on-demand only)**
    On-save auto-validation disabled
    in v0.6.2; LSP is sole real-time
    diagnostics provider.
end note

@enduml
