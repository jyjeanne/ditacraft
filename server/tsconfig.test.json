{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "out",
    "composite": false,
    "declaration": false,
    "types": ["mocha", "node"],
    "typeRoots": ["./node_modules/@types", "../node_modules/@types"]
  },
  "include": [
    "src/**/*",
    "test/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
