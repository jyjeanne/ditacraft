{
  "name": "ditacraft-lsp-server",
  "description": "DitaCraft DITA Language Server",
  "version": "0.7.3",
  "private": true,
  "main": "./out/server.js",
  "scripts": {
    "test": "tsc -p tsconfig.test.json && mocha out/test/**/*.test.js --ui tdd --timeout 10000",
    "coverage": "tsc -p tsconfig.test.json && npx c8 mocha out/test/**/*.test.js --ui tdd --timeout 10000",
    "coverage:check": "npx c8 check-coverage",
    "coverage:report": "npx c8 report --reporter=html --reporter=text --reporter=lcov"
  },
  "dependencies": {
    "fast-xml-parser": "^5.5.12",
    "salve-annos": "^1.2.4",
    "saxes": "^6.0.0",
    "typesxml": "^1.17.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11",
    "vscode-uri": "^3.0.8",
    "xregexp": "^4.4.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.1",
    "c8": "^10.1.3",
    "mocha": "^11.7.5"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5",
    "diff": ">=8.0.3"
  },
  "c8": {
    "include": [
      "out/src/**/*.js"
    ],
    "exclude": [
      "out/test/**"
    ],
    "reporter": [
      "text",
      "lcov"
    ],
    "report-dir": "coverage",
    "check-coverage": true,
    "lines": 90,
    "statements": 90,
    "functions": 90,
    "branches": 80
  }
}
